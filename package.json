{
  "name": "foundation",
  "description": "rushilrai's monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "turbo format && prettier --write \"./*.{js,cjs,mjs,json,md,yml,yaml}\"",
    "format:check": "turbo check && prettier --check \"./*.{js,cjs,mjs,json,md,yml,yaml}\""
  },
  "keywords": [],
  "author": "Rushil Rai",
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=24.0.0"
  },
  "trustedDependencies": [
    "@clerk/shared",
    "@tailwindcss/oxide",
    "esbuild",
    "msw",
    "sharp",
    "unrs-resolver"
  ],
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "oxlint": "^1.70.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  }
}
